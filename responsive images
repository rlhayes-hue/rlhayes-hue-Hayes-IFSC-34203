// Handles idle/standing behavior
export function stand(player) {
    player.velocity.x = 0;

    if (player.input.left) {
        player.setState("move");
    }

    if (player.input.down) {
        player.setState("sit");
    }

    if (player.input.fire) {
        player.turret.activate();
    }

    player.playAnimation("stand");
}

// Controls turret behavior
export class Turret {
    constructor(player) {
        this.player = player;
        this.cooldown = 0;
    }

    update(deltaTime) {
        if (this.cooldown > 0) {
            this.cooldown -= deltaTime;
        }
    }

    activate() {
        if (this.cooldown <= 0) {
            this.fireProjectile("forward");
            this.cooldown = 0.5;
        }
    }

    activateLow() {
        if (this.cooldown <= 0) {
            this.fireProjectile("low");
            this.cooldown = 0.5;
        }
    }

    fireProjectile(direction) {
        console.log(`Firing ${direction} shot`);
        // spawn projectile logic here
    }
}

